#!/bin/bash
set -e

# --- THAY ĐỔI: Nhận 7 tham số từ Scheduler ---
ZIP_FILE_PATH="$1"
WP_AUTHOR="$2"
WP_PATH="$3"
WP_PREFIX="$4"
ZIP_FILENAME="$5"
TELEGRAM_BOT_TOKEN="$6" # <-- Tham số mới
TELEGRAM_CHAT_ID="$7"   # <-- Tham số mới
# --- KẾT THÚC THAY ĐỔI ---

# --- Cấu hình ---
WEB_USER="nginx" 
# Đường dẫn đến script Báo cáo (Bash)
REPORT_SCRIPT="/home/khue/update_report.sh" 
# Đường dẫn WP-CLI
WP_CLI_PATH="/usr/local/bin/wp"

# --- THAY ĐỔI: Xóa logic đọc file .telegram_env ---
# Biến TELEGRAM_BOT_TOKEN và TELEGRAM_CHAT_ID đã được nhận từ tham số
if [ -z "$TELEGRAM_BOT_TOKEN" ] || [ -z "$TELEGRAM_CHAT_ID" ]; then
    echo "Lỗi: TELEGRAM_BOT_TOKEN hoặc TELEGRAM_CHAT_ID (từ meta.json) rỗng."
    exit 1 # Thoát ngay lập tức
fi
# --- KẾT THÚC THAY ĐỔI ---

# --- Hàm gửi thông báo (ĐÃ SỬA) ---
send_telegram_notification() {
    local message="$1"
    local target_chat_id="$2" 

    if [ -z "$target_chat_id" ]; then
        echo "Lỗi: target_chat_id bị rỗng khi gọi hàm send_telegram_notification"
        return 1
    fi
    
    # Sử dụng biến $TELEGRAM_BOT_TOKEN (toàn cục) nhận từ tham số $6
    curl -s -X POST "https://api.telegram.org/bot${TELEGRAM_BOT_TOKEN}/sendMessage" \
        -d "chat_id=${target_chat_id}" \
        -d "text=${message}" \
        -d "disable_web_page_preview=true" > /dev/null
}

# --- Logic chính ---
ZIP_NAME=$(basename "$ZIP_FILE_PATH")
REMOTE_TEMP_DIR=$(mktemp -d /tmp/upload_${ZIP_NAME%.zip}.XXXXXX)
chmod 755 "$REMOTE_TEMP_DIR" 

IMPORT_STATUS="FAILURE"
IMPORT_OUTPUT=""
IMAGE_COUNT=0

# Bẫy dọn dẹp (trap)
function cleanup {
    echo "Dọn dẹp $REMOTE_TEMP_DIR..."
    rm -rf "$REMOTE_TEMP_DIR"
    
    local FINAL_MESSAGE=""
    
    if [ "$IMPORT_STATUS" = "SUCCESS" ]; then
        echo "Dang tao bao cao tom tat..."
        SUMMARY_REPORT=$(bash "$REPORT_SCRIPT" "$WP_AUTHOR" "$WP_PREFIX" "$IMAGE_COUNT" "$ZIP_FILENAME")
        FINAL_MESSAGE="$SUMMARY_REPORT"
    else
        ERROR_DETAILS=$(echo "$IMPORT_OUTPUT" | tail -n 5)
        FINAL_MESSAGE="❌ THẤT BẠI: File '$ZIP_NAME' (User: $WP_AUTHOR) import lỗi.\n\nLỗi:\n${ERROR_DETAILS}"
    fi
    
    # --- THAY ĐỔI: Xóa logic chọn Chat ID ---
    # Sử dụng trực tiếp $TELEGRAM_CHAT_ID nhận từ tham số $7
    local TARGET_CHAT_ID="$TELEGRAM_CHAT_ID"
    # --- KẾT THÚC THAY ĐỔI ---
    
    echo "$FINAL_MESSAGE"
    send_telegram_notification "$FINAL_MESSAGE" "$TARGET_CHAT_ID"
}
trap cleanup EXIT 

echo "--- Bắt đầu xử lý $ZIP_NAME ---"

# ... (Logic đếm ảnh giữ nguyên) ...
echo "Dang dem anh trong file..."
COUNT_OUTPUT=$(unzip -l "$ZIP_FILE_PATH" | grep -Eic '(\.webp|\.jpg|\.png)$' || echo 0)
IMAGE_COUNT=$(echo "$COUNT_OUTPUT" | tail -n 1) 
echo "Tim thay $IMAGE_COUNT anh."
if [ "$IMAGE_COUNT" -eq 0 ]; then
    IMPORT_STATUS="FAILURE"
    IMPORT_OUTPUT="Loi: Khong tim thay file anh nao (.webp, .jpg, .png) trong file zip."
    exit 1
fi

# ... (Logic giải nén và import giữ nguyên) ...
mv "$ZIP_FILE_PATH" "$REMOTE_TEMP_DIR/"
cd "$REMOTE_TEMP_DIR"

unzip -O CP437 -o "$ZIP_NAME" -d extracted_images || true
chmod -R 755 extracted_images

echo "Import vào $WP_PATH (Author: $WP_AUTHOR)..."
cd "$WP_PATH"
shopt -s nullglob
shopt -s globstar 

# Sử dụng quyền sudo đã được cấp trong visudo
IMPORT_OUTPUT=$(sudo -u $WEB_USER $WP_CLI_PATH media import "$REMOTE_TEMP_DIR/extracted_images/"**/*.{webp,jpg,png} --user="$WP_AUTHOR" 2>&1 || true)

if echo "$IMPORT_OUTPUT" | grep -q -E "(Error:|usage:|Failed)"; then
    IMPORT_STATUS="FAILURE"
else
    IMPORT_STATUS="SUCCESS"
fi

echo "$IMPORT_OUTPUT"
echo "--- Hoàn thành xử lý $ZIP_NAME ---"